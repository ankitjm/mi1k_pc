# ThumbnailOS — Environment Variables Template
# Copy to .env and fill in all values before deploying
# Never commit .env to version control

# =============================================================================
# APP
# =============================================================================
NODE_ENV=production
APP_PORT=3000
APP_URL=https://thumbnailos.in

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://thumbnailos:CHANGE_ME_PASSWORD@localhost:5432/thumbnailos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=thumbnailos
DB_USER=thumbnailos
DB_PASSWORD=CHANGE_ME_PASSWORD

# =============================================================================
# YOUTUBE DATA API v3
# =============================================================================
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=AIzaSy_CHANGE_ME

# =============================================================================
# ANTHROPIC (Claude API)
# =============================================================================
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# Model to use for thumbnail analysis
CLAUDE_MODEL=claude-sonnet-4-6

# =============================================================================
# BREVO (Email)
# =============================================================================
# Get from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-CHANGE_ME
BREVO_SENDER_EMAIL=hello@thumbnailos.in
BREVO_SENDER_NAME=ThumbnailOS
# Template IDs (create in Brevo dashboard)
BREVO_TEMPLATE_OUTREACH=1
BREVO_TEMPLATE_AUDIT_DELIVERY=2
BREVO_TEMPLATE_DAY3_FOLLOWUP=3
BREVO_TEMPLATE_WELCOME=4
BREVO_TEMPLATE_ONBOARDING_1=5
BREVO_TEMPLATE_ONBOARDING_2=6
BREVO_TEMPLATE_ONBOARDING_3=7

# =============================================================================
# RAZORPAY
# =============================================================================
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME_SECRET
# Webhook secret (set in Razorpay Dashboard → Webhooks)
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
# Subscription plan IDs (create in Razorpay dashboard)
RAZORPAY_PLAN_STARTER=plan_CHANGE_ME
RAZORPAY_PLAN_PRO=plan_CHANGE_ME

# =============================================================================
# AIRTABLE
# =============================================================================
# Get from: https://airtable.com/account → API
AIRTABLE_API_KEY=pat_CHANGE_ME
AIRTABLE_BASE_ID=app_CHANGE_ME
# Table names (must match exactly)
AIRTABLE_TABLE_CUSTOMERS=Customers
AIRTABLE_TABLE_OUTREACH=Outreach
AIRTABLE_TABLE_PIPELINE=Pipeline
AIRTABLE_TABLE_MRR=MRR Dashboard

# =============================================================================
# WHATSAPP BUSINESS (Phase 2 — leave blank for now)
# =============================================================================
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# =============================================================================
# SECURITY
# =============================================================================
# Random 32-char string — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING
SESSION_SECRET=CHANGE_ME_ANOTHER_32_CHAR_STRING

# =============================================================================
# PIPELINE CONFIG
# =============================================================================
# Number of recent videos to analyze per channel
PIPELINE_VIDEOS_PER_CHANNEL=10
# Use mock data instead of live APIs (set true in dev/testing)
PIPELINE_USE_MOCK=false
# Output directory for generated PDFs
PDF_OUTPUT_DIR=/home/deploy/thumbnailos/output/pdfs
